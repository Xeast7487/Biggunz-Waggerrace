---
import Layout from '../layouts/Layout.astro';
import cfg from '../data/config.json';
---
<Layout>

<!-- ═══ NAV ══════════════════════════════════════════════════════════ -->
<header id="nav">
  <div class="nav-inner">
    <a href="/" class="nav-logo">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="#FFD700"><path d="M2 7l5 5 5-10 5 10 5-5-3 13H5L2 7z"/></svg>
      <span class="logo-main">BIGGUNZ</span>
      <span class="logo-sub">WAGGER RACE</span>
    </a>
    <nav class="nav-links">
      <a href="#leaderboard">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M3 21v-4h4V7H3V3h6v14h4V10h6v11H3zM7 21v-2H5v2h2zm6 0v-9h-2v9h2zm6 0V12h-2v9h2z"/></svg>
        TOP 20
      </a>
      <a href="#prizes">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 12V22H4V12"/><path d="M22 7H2v5h20V7z"/><path d="M12 22V7"/><path d="M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7z"/><path d="M12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z"/></svg>
        RÉCOMPENSES
      </a>
      <a href="#howto">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4M12 8h.01"/></svg>
        COMMENT ÇA MARCHE
      </a>
    </nav>
    <a href={cfg.streamer.twitch_url} target="_blank" class="nav-twitch">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M11.571 4.714h1.715v5.143H11.57zm4.715 0H18v5.143h-1.714zM6 0L1.714 4.286v15.428h5.143V24l4.286-4.286h3.428L22.286 12V0zm14.571 11.143l-3.428 3.428h-3.429l-3 3v-3H6.857V1.714h13.714z"/></svg>
      TWITCH
    </a>
    <a href={cfg.streamer.affiliate_url} target="_blank" class="nav-cta">
      🚀 JOUER SUR HYPE
    </a>
    <button id="burger" class="burger">
      <span></span><span></span>
    </button>
  </div>
</header>

<div id="mobile-nav" class="mobile-nav">
  <a href="#leaderboard">🏆 TOP 20</a>
  <a href="#prizes">🎁 RÉCOMPENSES</a>
  <a href="#howto">ℹ️ COMMENT ÇA MARCHE</a>
  <a href={cfg.streamer.affiliate_url} target="_blank" class="mob-cta">🚀 JOUER SUR HYPE.BET</a>
</div>

<!-- ═══ HERO ══════════════════════════════════════════════════════════ -->
<section class="hero">
  <div class="hero-bg"></div>
  <div class="hero-glow"></div>

  <div class="hero-inner">
    <!-- Left : headline -->
    <div class="hero-left">
      <p class="hero-tagline">JOUE SUR HYPE VIA MON LIEN<br/>ET MONTE DANS LE CLASSEMENT !</p>
      <div class="hero-headline">
        <span class="h-white">WAGGER.</span>
        <span class="h-pink">GAGNE.</span>
        <span class="h-cyan">ENCAISSE.</span>
      </div>
      <a href={cfg.streamer.affiliate_url} target="_blank" class="hero-cta">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="#FFD700"><path d="M2 7l5 5 5-10 5 10 5-5-3 13H5L2 7z"/></svg>
        JOUEZ SUR HYPE.BET
      </a>
    </div>

    <!-- Center : streamer photo -->
    <div class="hero-photo">
      <div class="streamer-photo-wrap">
        <img src="/streamer.png" alt="BIGGUNZ" class="streamer-img" />
      </div>
    </div>

    <!-- Right : Top 5 prizes -->
    <div class="hero-prizes">
      <div class="prizes-header">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="#FFD700"><path d="M12 2l2.4 7.4H22l-6.2 4.5 2.4 7.4L12 17l-6.2 4.3 2.4-7.4L2 9.4h7.6L12 2z"/></svg>
        TOP 5 PAYÉS
      </div>
      <div class="prizes-list">
        {cfg.prizes.map((p, i) => (
          <div class={`prize-row ${i === 0 ? 'prize-first' : ''}`}>
            <span class="prize-rank">
              {i === 0 ? <><svg width="14" height="14" viewBox="0 0 24 24" fill="#FFD700"><path d="M2 7l5 5 5-10 5 10 5-5-3 13H5L2 7z"/></svg> 1ER</> : `${i+1}E`}
            </span>
            <span class="prize-amount">{p.amount.toLocaleString('en-CA')} $</span>
          </div>
        ))}
      </div>
      <div class="prizes-deco">🎰 🎁 🪙</div>
    </div>
  </div>
</section>

<!-- ═══ STATS BAR ═════════════════════════════════════════════════════ -->
<div class="stats-bar">
  <div class="stat-item">
    <div class="stat-icon">📈</div>
    <div>
      <p class="stat-label">WAGGER TOTAL</p>
      <p class="stat-val" id="live-total">— —</p>
    </div>
  </div>
  <div class="stat-sep"></div>
  <div class="stat-item">
    <div class="stat-icon">🎯</div>
    <div>
      <p class="stat-label">FIN DU MOIS</p>
      <p class="stat-val" id="countdown">--j --h --m</p>
    </div>
  </div>
  <div class="stat-sep"></div>
  <div class="stat-item">
    <div class="stat-icon">🔥</div>
    <div>
      <p class="stat-label">MISE MOYENNE</p>
      <p class="stat-val" id="live-avg">— —</p>
    </div>
  </div>
</div>

<!-- ═══ MAIN CONTENT ══════════════════════════════════════════════════ -->
<main class="main-grid">

  <!-- LEADERBOARD -->
  <section class="leaderboard-section" id="leaderboard">
    <div class="lb-header">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="#FFD700"><path d="M2 7l5 5 5-10 5 10 5-5-3 13H5L2 7z"/></svg>
      TOP 20 – WAGGER DU MOIS ({cfg.streamer.month.split(' ')[0]})
      <span class="live-badge"><span class="live-dot"></span>LIVE</span>
      <span class="lb-updated" id="lb-updated"></span>
    </div>
    <table class="lb-table">
      <thead>
        <tr>
          <th>RANG</th>
          <th>JOUEUR</th>
          <th>WAGGER TOTAL</th>
        </tr>
      </thead>
      <tbody id="lb-body">
        <!-- Skeleton loading -->
        {Array.from({length: 10}).map((_, i) => (
          <tr class="lb-row rank-other lb-skeleton">
            <td class="col-rank"><span class="skel-block" style="width:30px"></span></td>
            <td class="col-name"><span class="skel-block" style={`width:${100 + (i % 3) * 30}px`}></span></td>
            <td class="col-wager"><span class="skel-block" style="width:80px;float:right"></span></td>
          </tr>
        ))}
      </tbody>
    </table>
  </section>

  <!-- RIGHT COLUMN -->
  <aside class="right-col">

    <!-- HOW TO -->
    <section class="card" id="howto">
      <h3 class="card-title pink">COMMENT ÇA MARCHE ?</h3>
      <div class="steps">
        <div class="step">
          <span class="step-num">1</span>
          <div>
            <p class="step-icon-text">🎰</p>
            <p>Joue sur Hype.bet<br/><span>via mon lien affilié</span></p>
          </div>
        </div>
        <div class="step">
          <span class="step-num">2</span>
          <div>
            <p class="step-icon-text">📈</p>
            <p>Place tes mises<br/><span>et augmente ton wager</span></p>
          </div>
        </div>
        <div class="step">
          <span class="step-num">3</span>
          <div>
            <p class="step-icon-text">🏆</p>
            <p>Monte dans le classement<br/><span>et gagne des récompenses !</span></p>
          </div>
        </div>
      </div>
      <a href={cfg.streamer.affiliate_url} target="_blank" class="card-cta">
        🚀 JOUER SUR HYPE.BET
      </a>
    </section>

    <!-- PRIZES -->
    <section class="card" id="prizes">
      <div class="prizes-card-header">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 12V22H4V12"/><path d="M22 7H2v5h20V7z"/><path d="M12 22V7"/><path d="M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7z"/><path d="M12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z"/></svg>
        <h3 class="card-title">RÉCOMPENSES ({cfg.streamer.month.split(' ')[0]})</h3>
      </div>
      <p class="prizes-total">TOTAL À DISTRIBUER : <strong>{cfg.prizes.reduce((s,p)=>s+p.amount,0).toLocaleString('en-CA')} $</strong></p>
      <div class="prizes-rows">
        {cfg.prizes.map((p, i) => (
          <div class={`prize-line ${i === 0 ? 'prize-line-first' : ''}`}>
            <span>{i === 0 ? '1ER' : `${i+1}E`}</span>
            <span class={i === 0 ? 'gold' : ''}>{p.amount.toLocaleString('en-CA')} $</span>
          </div>
        ))}
      </div>
      <a href="#leaderboard" class="card-cta-outline">VOIR LES RÉCOMPENSES</a>
    </section>

    <!-- JOIN CTA -->
    <section class="card card-join">
      <div class="join-trophy">🏆</div>
      <div class="join-text">
        <p class="join-title">REJOINS LA RACE !</p>
        <p>Plus tu mises,<br/>plus tu montes.<br/>Plus tu montes,<br/>plus tu gagnes !</p>
      </div>
    </section>

  </aside>
</main>

<!-- ═══ LIVE TOAST ═══════════════════════════════════════════════════ -->
<div id="live-toast" aria-live="polite"></div>

<!-- ═══ FOOTER ════════════════════════════════════════════════════════ -->
<footer>
  <div class="foot-inner">
    <a href="/" class="nav-logo">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="#FFD700"><path d="M2 7l5 5 5-10 5 10 5-5-3 13H5L2 7z"/></svg>
      <span class="logo-main">BIGGUNZ</span>
      <span class="logo-sub">WAGGER RACE</span>
    </a>
    <div class="foot-center">
      <p class="foot-slogan">Joue. Wagger. Gagne.</p>
      <p class="foot-disclaimer">18+ | Le jeu comporte des risques. Jouez de manière responsable.</p>
    </div>
    <div class="foot-links">
      <a href={cfg.streamer.twitch_url} target="_blank" class="foot-twitch">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M11.571 4.714h1.715v5.143H11.57zm4.715 0H18v5.143h-1.714zM6 0L1.714 4.286v15.428h5.143V24l4.286-4.286h3.428L22.286 12V0zm14.571 11.143l-3.428 3.428h-3.429l-3 3v-3H6.857V1.714h13.714z"/></svg>
        biggunzvortex
      </a>
      <a href={cfg.streamer.affiliate_url} target="_blank" class="nav-cta">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="#FFD700"><path d="M2 7l5 5 5-10 5 10 5-5-3 13H5L2 7z"/></svg>
        JOUER SUR HYPE.BET
      </a>
    </div>
  </div>
</footer>

</Layout>

<script define:vars={{ raceEnd: cfg.race_end }}>
  // ── Nav ───────────────────────────────────────────────────────
  const nav = document.getElementById('nav');
  window.addEventListener('scroll', () => nav?.classList.toggle('scrolled', window.scrollY > 10), { passive: true });
  const burger = document.getElementById('burger');
  const mNav   = document.getElementById('mobile-nav');
  burger?.addEventListener('click', () => mNav?.classList.toggle('open'));
  mNav?.querySelectorAll('a').forEach(a => a.addEventListener('click', () => mNav.classList.remove('open')));

  // ── Countdown ────────────────────────────────────────────────
  function updateCountdown() {
    const end  = new Date(raceEnd).getTime();
    const diff = end - Date.now();
    const el   = document.getElementById('countdown');
    if (!el) return;
    if (diff <= 0) { el.textContent = 'TERMINÉ'; return; }
    const d = Math.floor(diff / 86400000);
    const h = Math.floor((diff % 86400000) / 3600000);
    const m = Math.floor((diff % 3600000) / 60000);
    el.textContent = `${d}j ${String(h).padStart(2,'0')}h ${String(m).padStart(2,'0')}m`;
  }
  updateCountdown();
  setInterval(updateCountdown, 30000);

  // ── Helpers ──────────────────────────────────────────────────
  const fmt = n => '$' + n.toLocaleString('en-CA', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
  const COLORS = ['#FFD700','#00D4FF','#00FF88','#FF2D9B','#BF5FFF','#FF6B00'];
  const CROWN_GOLD   = `<svg width="14" height="14" viewBox="0 0 24 24" fill="#FFD700"><path d="M2 7l5 5 5-10 5 10 5-5-3 13H5L2 7z"/></svg>`;
  const CROWN_SILVER = `<svg width="14" height="14" viewBox="0 0 24 24" fill="#C0C0C0"><path d="M2 7l5 5 5-10 5 10 5-5-3 13H5L2 7z"/></svg>`;
  const CROWN_BRONZE = `<svg width="14" height="14" viewBox="0 0 24 24" fill="#CD7F32"><path d="M2 7l5 5 5-10 5 10 5-5-3 13H5L2 7z"/></svg>`;

  // ── Leaderboard API ──────────────────────────────────────────
  async function loadLeaderboard() {
    try {
      const res  = await fetch('/api/leaderboard');
      const data = await res.json();

      if (!res.ok || !data.leaderboard) throw new Error(data.error || 'Erreur API');

      // Stats
      document.getElementById('live-total').textContent = fmt(data.totalWager);
      document.getElementById('live-avg').textContent   = fmt(data.avgWager);

      // Dernière mise à jour
      const updEl = document.getElementById('lb-updated');
      if (updEl) {
        const t = new Date(data.lastUpdated);
        updEl.textContent = `MÀJ ${String(t.getHours()).padStart(2,'0')}:${String(t.getMinutes()).padStart(2,'0')}`;
      }

      // Tableau
      const tbody = document.getElementById('lb-body');
      if (!tbody) return;
      tbody.innerHTML = '';

      if (!data.leaderboard.length) {
        tbody.innerHTML = `<tr><td colspan="3" class="lb-empty">Aucun joueur pour l'instant — La race commence !</td></tr>`;
        return;
      }

      data.leaderboard.forEach(p => {
        const isTop3 = p.rank <= 3;
        const crown  = p.rank === 1 ? CROWN_GOLD : p.rank === 2 ? CROWN_SILVER : p.rank === 3 ? CROWN_BRONZE : '';
        const color  = isTop3 ? '' : `color: ${COLORS[(p.rank - 4) % COLORS.length]}`;
        const tr     = document.createElement('tr');
        tr.className = `lb-row rank-${isTop3 ? p.rank : 'other'}`;
        tr.innerHTML = `
          <td class="col-rank">${crown}${p.rank}</td>
          <td class="col-name" style="${color}">${p.name}</td>
          <td class="col-wager">${fmt(p.wager)}</td>`;
        tbody.appendChild(tr);
      });

    } catch (err) {
      console.error('Leaderboard error:', err);
      const tbody = document.getElementById('lb-body');
      if (tbody) tbody.innerHTML = `<tr><td colspan="3" class="lb-empty">⚠️ Erreur de chargement</td></tr>`;
    }
  }

  // Charger au démarrage + toutes les 5 minutes
  loadLeaderboard();
  setInterval(loadLeaderboard, 5 * 60 * 1000);
</script>

<!-- Live leaderboard simulation -->
<script define:vars={{ lbData: cfg.leaderboard }}>
(function () {
  const COLORS = ['#FFD700','#00D4FF','#00FF88','#FF2D9B','#BF5FFF','#FF6B00'];
  const nameColor = r => COLORS[(r - 4) % COLORS.length];
  const fmt = n => '$' + n.toLocaleString('en-CA', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
  const rand = (a, b) => Math.random() * (b - a) + a;
  const randInt = (a, b) => Math.floor(rand(a, b + 1));

  let players = lbData.map(p => ({ ...p }));
  let prevWagers = {};
  players.forEach(p => { prevWagers[p.name] = p.wager; });

  // Smooth number count-up
  function countUp(el, from, to, ms) {
    ms = ms || 700;
    const t0 = performance.now();
    const diff = to - from;
    function tick(now) {
      const p = Math.min((now - t0) / ms, 1);
      const e = 1 - (1 - p) * (1 - p);
      el.textContent = fmt(from + diff * e);
      if (p < 1) requestAnimationFrame(tick);
      else el.textContent = fmt(to);
    }
    requestAnimationFrame(tick);
  }

  // Toast
  function showToast(html) {
    const t = document.getElementById('live-toast');
    if (!t) return;
    t.innerHTML = html;
    t.style.opacity = '1';
    t.style.transform = 'translateY(0)';
    clearTimeout(t._hide);
    t._hide = setTimeout(() => {
      t.style.opacity = '0';
      t.style.transform = 'translateY(12px)';
    }, 3200);
  }

  function rankSVG(r) {
    const fills = { 1: '#FFD700', 2: '#C0C0C0', 3: '#CD7F32' };
    if (!fills[r]) return '';
    return `<svg width="14" height="14" viewBox="0 0 24 24" fill="${fills[r]}"><path d="M2 7l5 5 5-10 5 10 5-5-3 13H5L2 7z"/></svg>`;
  }

  function render(updated, rankChanges) {
    const tbody = document.querySelector('.lb-table tbody');
    if (!tbody) return;

    players.forEach((p, i) => {
      const row = tbody.rows[i];
      if (!row) return;

      row.className = 'lb-row rank-' + (p.rank <= 3 ? p.rank : 'other');

      // Rank cell
      const change = rankChanges[p.name] || 0;
      let badge = '';
      if (change > 0) badge = `<span class="rc-up">▲${change}</span>`;
      else if (change < 0) badge = `<span class="rc-down">▼${Math.abs(change)}</span>`;
      row.cells[0].innerHTML = rankSVG(p.rank) + p.rank + badge;

      // Name cell
      row.cells[1].textContent = p.name;
      row.cells[1].style.color = p.rank > 3 ? nameColor(p.rank) : '';

      // Wager cell
      if (updated.includes(p.name)) {
        const prev = prevWagers[p.name] || p.wager;
        countUp(row.cells[2], prev, p.wager);
        row.cells[2].classList.add('wager-flash');
        setTimeout(() => row.cells[2].classList.remove('wager-flash'), 1200);
      }

      // Row glow if climbed
      if (change > 0) {
        row.classList.add('row-rank-up');
        setTimeout(() => row.classList.remove('row-rank-up'), 1500);
      }
    });

    // Save wagers
    players.forEach(p => { prevWagers[p.name] = p.wager; });

    // Stats bar update
    const total = players.reduce((s, p) => s + p.wager, 0);
    const avg = total / players.length;

    const totalEl = document.getElementById('live-total');
    const avgEl   = document.getElementById('live-avg');
    if (totalEl) {
      const prev = parseFloat(totalEl.dataset.val || total);
      totalEl.dataset.val = total;
      countUp(totalEl, prev, total);
    }
    if (avgEl) {
      const prev = parseFloat(avgEl.dataset.val || avg);
      avgEl.dataset.val = avg;
      countUp(avgEl, prev, avg);
    }
  }

  function tick() {
    const n = randInt(1, 3);
    const indices = new Set();
    while (indices.size < n) indices.add(randInt(0, players.length - 1));

    const oldRanks = {};
    players.forEach(p => { oldRanks[p.name] = p.rank; });

    const updated = [];
    let toastName = null, toastInc = 0;

    indices.forEach(idx => {
      const r = players[idx].rank;
      const inc = r <= 3  ? rand(120, 950) :
                  r <= 8  ? rand(60,  520) : rand(25, 320);
      players[idx].wager += inc;
      updated.push(players[idx].name);
      if (inc > toastInc) { toastInc = inc; toastName = players[idx].name; }
    });

    players.sort((a, b) => b.wager - a.wager);
    players.forEach((p, i) => { p.rank = i + 1; });

    const rankChanges = {};
    players.forEach(p => { rankChanges[p.name] = oldRanks[p.name] - p.rank; });

    if (toastName) {
      const newRank = players.find(p => p.name === toastName).rank;
      const climbed = rankChanges[toastName] > 0;
      const rankPart = climbed
        ? ` &nbsp;<span style="color:#00FF88;font-family:'Orbitron',monospace;font-size:0.75rem">▲ RANG ${newRank}</span>`
        : '';
      showToast(
        `🎰 <strong>${toastName}</strong> vient de miser ` +
        `<span style="color:#FFD700;font-family:'Orbitron',monospace">${fmt(toastInc)}</span>` +
        rankPart
      );
    }

    render(updated, rankChanges);
  }

  document.addEventListener('DOMContentLoaded', () => {
    const total = players.reduce((s, p) => s + p.wager, 0);
    const totalEl = document.getElementById('live-total');
    const avgEl   = document.getElementById('live-avg');
    if (totalEl) totalEl.dataset.val = total;
    if (avgEl)   avgEl.dataset.val   = total / players.length;

    function schedule() {
      setTimeout(() => { tick(); schedule(); }, randInt(3500, 7500));
    }
    setTimeout(schedule, 2500);
  });
})();
</script>

<style>
  /* ── NAV ─────────────────────────────────────────────────── */
  #nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    background: rgba(6,6,15,0.85); backdrop-filter: blur(16px);
    border-bottom: 1px solid rgba(255,45,155,0.2);
    transition: border-color 0.3s;
  }
  #nav.scrolled { border-bottom-color: rgba(255,45,155,0.5); }
  .nav-inner {
    max-width: 1200px; margin: 0 auto;
    display: flex; align-items: center; gap: 1.5rem;
    padding: 0 2rem; height: 64px;
  }
  .nav-logo { display: flex; align-items: center; gap: 0.5rem; flex-shrink: 0; font-family: 'Rajdhani', sans-serif; font-weight: 700; }
  .logo-main { font-size: 1.1rem; font-weight: 900; color: var(--pink); letter-spacing: 0.05em; font-family: 'Orbitron', monospace; }
  .logo-sub  { font-size: 0.62rem; font-weight: 700; color: var(--cyan); letter-spacing: 0.12em; margin-top: 1px; }
  .nav-links { display: flex; gap: 0.25rem; margin-left: auto; }
  .nav-links a {
    display: flex; align-items: center; gap: 0.4rem;
    padding: 0.5rem 0.9rem; font-size: 0.8rem; font-weight: 700;
    color: rgba(255,255,255,0.6); letter-spacing: 0.06em;
    border-radius: 6px; transition: color 0.2s, background 0.2s;
  }
  .nav-links a:hover { color: var(--white); background: rgba(255,255,255,0.06); }
  .nav-cta {
